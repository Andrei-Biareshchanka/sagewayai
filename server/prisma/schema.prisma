generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Parable {
  id         String        @id @default(cuid())
  title      String
  content    String        @db.Text
  moral      String
  source     String?
  readTime   Int
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  category   Category      @relation(fields: [categoryId], references: [id])
  categoryId String
  dailies    DailyParable[]

  @@unique([title, categoryId])
  @@index([categoryId])
}

model Category {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  description   String?
  color         String?
  parablesCount Int       @default(0)
  parables      Parable[]
}

model DailyParable {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  parable   Parable  @relation(fields: [parableId], references: [id])
  parableId String
}

